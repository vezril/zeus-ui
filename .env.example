# Zeus configuration.
#
# Zeus is a Backend-for-Frontend: the browser only ever talks to Zeus's own
# /api/apollo/* routes, which speak gRPC to Apollo server-side. The Apollo
# endpoint, bearer token, and TLS trust therefore live here as SERVER-side
# config only — NEVER as NEXT_PUBLIC_* (that would ship secrets to the browser).
#
# When the client is left on fixtures/mocks (the default during development,
# before Apollo is reachable), none of these are required.

# host:port of Apollo's gRPC surface (server-side).
#   e.g. apollo.apollo.svc.cluster.local:9090
APOLLO_ENDPOINT=

# Optional bearer token, injected into gRPC metadata as `authorization: Bearer`.
# Server-side only — do NOT prefix with NEXT_PUBLIC_.
APOLLO_TOKEN=

# Whether to dial Apollo over TLS (true) vs h2c/plaintext (false), matching
# Apollo's api-security config.
APOLLO_TLS_ENABLED=false

# Trust anchor (PEM) or path used when APOLLO_TLS_ENABLED=true. Server-side only.
APOLLO_TLS_CA=
