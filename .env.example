# Zeus configuration.
#
# Zeus is a Backend-for-Frontend: the browser only ever talks to Zeus's own
# /api/apollo/* routes, which speak gRPC to Apollo server-side. The Apollo
# endpoint, bearer token, and TLS trust therefore live here as SERVER-side
# config only — NEVER as NEXT_PUBLIC_* (that would ship secrets to the browser).
#
# When the client is left on fixtures/mocks (the default during development,
# before Apollo is reachable), none of these are required.

# --- Browser client selector (NOT a secret) ---
# The typed ApolloClient uses in-browser fixtures by default. Set this to the
# same-origin BFF base path to swap in the live HTTP client that calls Zeus's
# own /api/apollo/* routes (task 7.1). Leave unset to stay on fixtures.
#   NEXT_PUBLIC_APOLLO_API_BASE=/api/apollo
NEXT_PUBLIC_APOLLO_API_BASE=

# --- Server-side Apollo connection (BFF only) ---

# host:port of Apollo's gRPC surface (server-side).
#   e.g. apollo.apollo.svc.cluster.local:9090
APOLLO_ENDPOINT=

# Optional bearer token, injected into gRPC metadata as `authorization: Bearer`.
# Server-side only — do NOT prefix with NEXT_PUBLIC_.
APOLLO_TOKEN=

# Whether to dial Apollo over TLS (true) vs h2c/plaintext (false), matching
# Apollo's api-security config.
APOLLO_TLS_ENABLED=false

# Trust anchor (PEM) or path used when APOLLO_TLS_ENABLED=true. Server-side only.
APOLLO_TLS_CA=

# ===========================================================================
# Hermes module (HermesMQ topics). Unlike Apollo (gRPC), HermesMQ is REST, so
# the BFF (/api/hermes/*) proxies its /v1 REST admin API. Same secret boundary:
# the token is server-side only, never NEXT_PUBLIC_.
# ===========================================================================

# --- Browser client selector (NOT a secret) ---
# The typed HermesClient uses in-browser fixtures by default. Set to the
# same-origin BFF base path to use the live client. Leave unset for fixtures.
#   NEXT_PUBLIC_HERMES_API_BASE=/api/hermes
NEXT_PUBLIC_HERMES_API_BASE=

# --- Server-side HermesMQ connection (BFF only) ---

# Base URL of HermesMQ's REST API (server-side). HermesMQ serves HTTP on 8080.
#   e.g. http://hermes.hermes.svc.cluster.local:8080
HERMES_ENDPOINT=

# Optional bearer token for HermesMQ's auth'd /v1 admin API, sent as
# `Authorization: Bearer`. Server-side only — do NOT prefix with NEXT_PUBLIC_.
# Leave empty when HermesMQ runs open/single-tenant (its default).
HERMES_TOKEN=

# Naming prefix for the Zeus-managed inspector subscriptions the Playground's
# live tap uses ({prefix}-{topic}). Server-side; defaults to "zeus-inspector".
# Keep the default so the browser's real-subscriber count recognizes them.
HERMES_INSPECTOR_PREFIX=zeus-inspector

# The dead-letter topic HermesMQ routes dead-lettered messages to (matches
# HermesMQ's own dead-letter-topic config). Server-side. When unset, the
# Dead-letters view shows a "not configured" state.
HERMES_DLQ_TOPIC=
